{
  "$schema": "Climbing Gym Output Schema v1.0",
  "fields": {
    "name": {
      "type": "string",
      "required": true,
      "description": "Official gym name"
    },
    "address": {
      "type": "string",
      "required": true,
      "description": "Full street address"
    },
    "city": {
      "type": "string",
      "required": true,
      "description": "City name"
    },
    "region": {
      "type": "string",
      "required": true,
      "description": "2-letter US state code (TX, CA, NY, etc.)"
    },
    "country": {
      "type": "string",
      "required": true,
      "default": "US",
      "description": "2-letter country code"
    },
    "latitude": {
      "type": "number",
      "required": true,
      "description": "Decimal latitude (e.g., 29.6612)"
    },
    "longitude": {
      "type": "number",
      "required": true,
      "description": "Decimal longitude (e.g., -98.4485)"
    },
    "phone": {
      "type": "string",
      "required": false,
      "format": "+1XXXXXXXXXX",
      "description": "Phone number with country code, no dashes"
    },
    "email": {
      "type": "string",
      "required": false,
      "description": "Primary contact email"
    },
    "website": {
      "type": "string",
      "required": true,
      "description": "Official website URL"
    },
    "hero_image": {
      "type": "string",
      "required": true,
      "description": "Primary photo URL (Google Photos URL)"
    },
    "google_maps_url": {
      "type": "string",
      "required": true,
      "description": "Google Maps place URL"
    },
    "amenities": {
      "type": "pipe_delimited",
      "required": false,
      "allowed_values": ["showers", "lockers", "cafe", "wifi", "parking", "sauna", "kids_zone", "pro_shop"],
      "description": "Standard amenities, pipe-delimited"
    },
    "custom_amenities": {
      "type": "pipe_delimited",
      "required": false,
      "examples": ["tension_board", "kilter_board", "moon_board", "yoga_studio", "fitness_area", "coworking", "coffee_on_tap", "youth_programs"],
      "description": "Non-standard amenities, pipe-delimited"
    },
    "climbing_types": {
      "type": "pipe_delimited",
      "required": true,
      "allowed_values": ["bouldering", "top_rope", "lead", "speed"],
      "description": "Climbing disciplines offered"
    },
    "route_reset_frequency": {
      "type": "enum",
      "required": false,
      "allowed_values": ["weekly", "biweekly", "monthly", "quarterly", "varies"],
      "description": "How often routes/problems are reset"
    },
    "total_routes": {
      "type": "integer",
      "required": false,
      "description": "Approximate number of routes/problems"
    },
    "wall_height_meters": {
      "type": "number",
      "required": false,
      "description": "Maximum wall height in meters"
    },
    "training_facilities": {
      "type": "pipe_delimited",
      "required": false,
      "allowed_values": ["hangboard", "campus_board", "treadwall", "weights", "spray_wall"],
      "description": "Training equipment available"
    },
    "rental_equipment": {
      "type": "pipe_delimited",
      "required": false,
      "allowed_values": ["shoes", "harness", "belay_device", "chalk_bag"],
      "description": "Rental gear available"
    },
    "beginner_friendly": {
      "type": "boolean",
      "required": false,
      "description": "Offers intro classes or beginner programs"
    },
    "day_pass_price_local": {
      "type": "number",
      "required": false,
      "description": "Adult day pass price (numeric only, no currency symbol)"
    },
    "student_discount": {
      "type": "boolean",
      "required": false,
      "description": "Offers student discount"
    },
    "membership_from_local": {
      "type": "number",
      "required": false,
      "description": "Lowest monthly membership price (numeric only)"
    },
    "difficulty_grades": {
      "type": "string",
      "required": false,
      "examples": ["V0-V10", "V-scale", "5.6-5.13a"],
      "description": "Grade range offered"
    },
    "working_hour": {
      "type": "pipe_delimited_hours",
      "required": false,
      "format": "mon:HH:MM-HH:MM|tue:HH:MM-HH:MM|wed:HH:MM-HH:MM|thu:HH:MM-HH:MM|fri:HH:MM-HH:MM|sat:HH:MM-HH:MM|sun:HH:MM-HH:MM",
      "description": "Operating hours in 24-hour format"
    },
    "about": {
      "type": "long_text",
      "required": true,
      "max_length": 5000,
      "description": "2-3 paragraph editorial overview in friendly local-guide tone"
    },
    "faq": {
      "type": "json_array",
      "required": true,
      "format": [{"question": "string", "answer": "string"}],
      "min_items": 5,
      "max_items": 8,
      "description": "Practical visitor Q&A pairs"
    },
    "why_climbers_like_it": {
      "type": "json_array",
      "required": true,
      "format": ["string"],
      "min_items": 3,
      "max_items": 5,
      "description": "Specific standout positives from reviews"
    },
    "rating_route_quality": {
      "type": "number",
      "required": true,
      "min": 1.0,
      "max": 5.0,
      "precision": 1,
      "description": "Route/problem quality (1.0-5.0)"
    },
    "rating_cleanliness": {
      "type": "number",
      "required": true,
      "min": 1.0,
      "max": 5.0,
      "precision": 1,
      "description": "Facility cleanliness (1.0-5.0)"
    },
    "rating_staff_friendliness": {
      "type": "number",
      "required": true,
      "min": 1.0,
      "max": 5.0,
      "precision": 1,
      "description": "Staff service quality (1.0-5.0)"
    },
    "rating_facilities": {
      "type": "number",
      "required": true,
      "min": 1.0,
      "max": 5.0,
      "precision": 1,
      "description": "Amenities and facilities quality (1.0-5.0)"
    },
    "rating_value_for_money": {
      "type": "number",
      "required": true,
      "min": 1.0,
      "max": 5.0,
      "precision": 1,
      "description": "Pricing vs quality (1.0-5.0)"
    },
    "rating_overall": {
      "type": "number",
      "required": true,
      "min": 1.0,
      "max": 5.0,
      "precision": 2,
      "calculated": true,
      "formula": "average(rating_route_quality, rating_cleanliness, rating_staff_friendliness, rating_facilities, rating_value_for_money)",
      "description": "Calculated average of 5 ratings"
    }
  }
}
